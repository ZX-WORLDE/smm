<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard • TicketBridge</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <style>
    body { background: #0b0f1a; }
    .glass { background: rgba(255,255,255,0.045); backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.08); }
    .section-header { font-size: 1.5rem; font-weight: 700; letter-spacing: -0.03em; }
    .nav-active { background: rgba(124, 58, 237, 0.2); color: #c4b5fd; }
    .ticket-row { transition: all .2s ease; }
    .ticket-row:hover { background: rgba(255,255,255,0.03); }
    .premium-btn { transition: all 0.2s cubic-bezier(0.4, 0.0, 0.2, 1); }
    .premium-btn:hover { transform: translateY(-1px); box-shadow: 0 10px 15px -3px rgb(124 58 237 / 0.3); }
  </style>
</head>
<body class="text-slate-200">
  <!-- Navbar -->
  <nav class="border-b border-white/10 bg-[#0b0f1a]/95 backdrop-blur-xl sticky top-0 z-50">
    <div class="max-w-screen-2xl mx-auto px-8 h-16 flex items-center justify-between">
      <div class="flex items-center gap-x-3">
        <div class="w-9 h-9 bg-violet-600 rounded-2xl flex items-center justify-center">
          <i class="fa-solid fa-headset text-white text-xl"></i>
        </div>
        <div>
          <span class="font-bold text-2xl tracking-tighter">TicketBridge</span>
          <span class="ml-2 text-[10px] px-2.5 py-0.5 bg-violet-600/30 text-violet-300 rounded-full align-middle font-mono">PRO</span>
        </div>
      </div>

      <div class="flex items-center gap-x-5 text-sm">
        <div class="hidden md:flex items-center gap-x-2 px-3 py-1 bg-emerald-500/10 text-emerald-400 rounded-2xl text-xs">
          <i class="fa-solid fa-circle text-[8px] animate-pulse"></i>
          <span>Render • Live</span>
        </div>
        <div class="flex items-center gap-x-2">
          <span class="text-slate-400">Welcome,</span>
          <span class="font-semibold"><%= username %></span>
        </div>
        <a href="/logout" class="px-5 py-2 text-xs font-medium border border-white/20 hover:bg-white/5 rounded-2xl flex items-center gap-x-2 transition-all active:scale-95">
          <i class="fa-solid fa-sign-out-alt"></i>
          <span class="hidden sm:inline">Logout</span>
        </a>
      </div>
    </div>
  </nav>

  <div class="max-w-screen-2xl mx-auto px-8 pt-9 pb-16">

    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-y-3 mb-8">
      <div>
        <h1 class="section-header">External Ticket Automation</h1>
        <p class="text-slate-400 mt-1">Manual + Webhook powered • Works perfectly on Render.com</p>
      </div>
      <div class="flex items-center gap-x-3">
        <div onclick="copyWebhook()" class="cursor-pointer flex items-center gap-x-2 px-4 py-2 bg-white/5 hover:bg-white/10 border border-white/10 rounded-2xl text-xs transition-all">
          <i class="fa-solid fa-link"></i>
          <span>Copy Webhook URL</span>
        </div>
      </div>
    </div>

    <!-- Alerts -->
    <% if (success) { %>
      <div class="mb-6 flex items-start gap-x-3 bg-emerald-500/10 border border-emerald-500/30 text-emerald-300 px-5 py-4 rounded-3xl">
        <i class="fa-solid fa-check-circle text-xl mt-0.5"></i>
        <div class="flex-1">
          <div class="font-semibold"><%= success %></div>
          <% if (ticketId) { %><div class="text-xs mt-1 font-mono text-emerald-400/80">Provider Ticket: <%= ticketId %></div><% } %>
        </div>
      </div>
    <% } %>
    <% if (error) { %>
      <div class="mb-6 flex items-start gap-x-3 bg-red-500/10 border border-red-500/30 text-red-300 px-5 py-4 rounded-3xl">
        <i class="fa-solid fa-exclamation-triangle text-xl mt-0.5"></i>
        <div><%= error %></div>
      </div>
    <% } %>

    <div class="grid grid-cols-1 xl:grid-cols-12 gap-6">

      <!-- Create Ticket Form -->
      <div class="xl:col-span-5">
        <div class="glass rounded-3xl p-7">
          <div class="flex items-center gap-x-3 mb-6">
            <div class="w-10 h-10 bg-violet-600 rounded-2xl flex items-center justify-center flex-shrink-0">
              <i class="fa-solid fa-plus text-white text-xl"></i>
            </div>
            <div>
              <div class="font-semibold text-2xl tracking-tight">Create Ticket</div>
              <div class="text-xs text-slate-400">Sends directly to your provider</div>
            </div>
          </div>

          <form action="/create-ticket" method="POST" class="space-y-5">
            <div>
              <label class="text-[10px] font-semibold tracking-[1.5px] text-slate-400 block mb-1.5">SUBJECT</label>
              <input type="text" name="subject" required placeholder="Orders - Cancel / Fake Complete"
                     class="w-full bg-[#111827] border border-white/10 focus:border-violet-500 text-sm rounded-2xl px-4 py-[13px] placeholder:text-slate-500">
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="text-[10px] font-semibold tracking-[1.5px] text-slate-400 block mb-1.5">ORDER ID</label>
                <input type="text" name="orderId" placeholder="ORD-784512" class="w-full bg-[#111827] border border-white/10 focus:border-violet-500 text-sm rounded-2xl px-4 py-[13px]">
              </div>
              <div>
                <label class="text-[10px] font-semibold tracking-[1.5px] text-slate-400 block mb-1.5">PRIORITY</label>
                <select name="priority" class="w-full bg-[#111827] border border-white/10 focus:border-violet-500 text-sm rounded-2xl px-4 py-[13px]">
                  <option value="Normal">Normal</option>
                  <option value="High">High</option>
                  <option value="Urgent">Urgent</option>
                </select>
              </div>
            </div>

            <div>
              <label class="text-[10px] font-semibold tracking-[1.5px] text-slate-400 block mb-1.5">MESSAGE</label>
              <textarea name="message" rows="5" required placeholder="Describe the issue in detail..." 
                        class="w-full bg-[#111827] border border-white/10 focus:border-violet-500 text-sm rounded-3xl px-4 py-3.5 placeholder:text-slate-500"></textarea>
            </div>

            <button type="submit" 
                    class="premium-btn w-full bg-white hover:bg-amber-300 active:scale-[0.985] text-slate-900 font-bold py-3.5 rounded-2xl flex items-center justify-center gap-x-2 text-sm tracking-[1.5px]">
              <i class="fa-solid fa-paper-plane"></i>
              <span>SEND TO PROVIDER</span>
            </button>
          </form>
        </div>
      </div>

      <!-- Webhook + History -->
      <div class="xl:col-span-7 space-y-6">
        
        <!-- Webhook Info -->
        <div class="glass rounded-3xl p-6">
          <div class="flex items-center justify-between mb-4">
            <div>
              <div class="font-semibold flex items-center gap-x-2">
                <i class="fa-solid fa-plug text-violet-400"></i> 
                <span>Webhook for Automatic Tickets</span>
              </div>
              <p class="text-xs text-slate-400 mt-0.5">Connect your main panel (smmgen.com) to send tickets here automatically</p>
            </div>
          </div>
          
          <div class="bg-black/40 border border-white/10 rounded-2xl p-4 font-mono text-xs break-all text-emerald-300">
            <%= webhookUrl %>
          </div>
          <div class="mt-3 text-[10px] text-slate-500 flex items-center gap-x-2">
            <span>Header:</span> <code class="bg-white/10 px-2 py-px rounded">X-API-KEY: smmgen_webhook_2026_secure_key</code>
          </div>
        </div>

        <!-- Ticket History -->
        <div class="glass rounded-3xl p-6">
          <div class="flex items-center justify-between mb-5">
            <div class="font-semibold text-xl">Ticket History</div>
            <div class="text-xs px-3 py-1 bg-white/5 rounded-full"><%= tickets.length %> tickets</div>
          </div>

          <% if (tickets.length === 0) { %>
            <div class="py-10 text-center">
              <i class="fa-solid fa-inbox text-5xl text-slate-700 mb-4"></i>
              <p class="text-slate-400">No tickets yet. Create one manually or via webhook.</p>
            </div>
          <% } else { %>
            <div class="space-y-3 max-h-[380px] overflow-auto pr-2 custom-scroll">
              <% tickets.forEach(t => { %>
                <div class="ticket-row flex justify-between items-start gap-x-4 bg-white/5 border border-white/10 rounded-2xl p-5 text-sm">
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-x-2 mb-1">
                      <span class="font-mono text-xs bg-white/10 px-2 py-0.5 rounded"> #<%= t.id %> </span>
                      <% if (t.demoMode) { %><span class="text-amber-400 text-xs">DEMO</span><% } %>
                      <% if (t.source === 'webhook') { %><span class="text-blue-400 text-xs">WEBHOOK</span><% } %>
                    </div>
                    <div class="font-medium text-white truncate"><%= t.subject %></div>
                    <div class="text-xs text-slate-400 mt-1 line-clamp-1"><%= t.message %></div>
                  </div>
                  <div class="text-right text-xs flex-shrink-0">
                    <div class="text-emerald-400 font-medium"><%= t.status %></div>
                    <% if (t.providerTicketId) { %>
                      <div class="font-mono text-emerald-300/70 mt-0.5"><%= t.providerTicketId %></div>
                    <% } %>
                    <div class="text-slate-500 mt-1"><%= new Date(t.createdAt).toLocaleDateString() %></div>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>

      </div>
    </div>

  </div>

  <script>
    function copyWebhook() {
      const url = "<%= webhookUrl %>";
      navigator.clipboard.writeText(url).then(() => {
        const originalText = event.currentTarget?.innerHTML || '';
        alert("Webhook URL copied to clipboard!\n\nUse this in your main panel to send tickets automatically.");
      });
    }
    
    // Keyboard shortcut hint
    console.log('%c[TicketBridge] Ready. Press Ctrl/Cmd + K for quick actions (future)', 'color:#475569');
  </script>
</body>
</html>
