<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login • External Ticket Bridge</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <style>
    body { background: linear-gradient(135deg, #0f172a 0%, #1e1135 100%); }
    .glass { background: rgba(255,255,255,0.06); backdrop-filter: blur(20px); }
    .premium-shadow { box-shadow: 0 25px 50px -12px rgb(0 0 0 / 0.4); }
  </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4">
  <div class="w-full max-w-md">
    <!-- Logo -->
    <div class="flex justify-center mb-8">
      <div class="flex items-center gap-x-3">
        <div class="w-12 h-12 bg-violet-600 rounded-2xl flex items-center justify-center">
          <i class="fa-solid fa-headset text-white text-3xl"></i>
        </div>
        <div>
          <h1 class="text-3xl font-bold text-white tracking-tight">TicketBridge</h1>
          <p class="text-violet-400 text-sm -mt-1">SMMGen External System</p>
        </div>
      </div>
    </div>

    <div class="glass border border-white/10 rounded-3xl p-8 premium-shadow">
      <div class="text-center mb-8">
        <h2 class="text-2xl font-semibold text-white">Sign in to continue</h2>
        <p class="text-slate-400 mt-2 text-sm">Access the advanced ticket automation system</p>
      </div>

      <% if (error) { %>
        <div class="mb-6 bg-red-500/10 border border-red-500/30 text-red-400 px-4 py-3 rounded-2xl text-sm flex items-center gap-x-2">
          <i class="fa-solid fa-exclamation-circle"></i>
          <span><%= error %></span>
        </div>
      <% } %>

      <form action="/login" method="POST" class="space-y-5">
        <div>
          <label class="block text-sm font-medium text-slate-300 mb-1.5">Username</label>
          <div class="relative">
            <i class="fa-solid fa-user absolute left-4 top-3.5 text-slate-500"></i>
            <input type="text" name="username" value="admin" required
                   class="w-full bg-white/5 border border-white/10 text-white pl-11 py-3 rounded-2xl focus:outline-none focus:border-violet-500 transition-colors">
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-slate-300 mb-1.5">Password</label>
          <div class="relative">
            <i class="fa-solid fa-lock absolute left-4 top-3.5 text-slate-500"></i>
            <input type="password" name="password" value="demo123" required
                   class="w-full bg-white/5 border border-white/10 text-white pl-11 py-3 rounded-2xl focus:outline-none focus:border-violet-500 transition-colors">
          </div>
        </div>

        <button type="submit"
                class="w-full mt-2 bg-violet-600 hover:bg-violet-700 transition-all text-white font-semibold py-3.5 rounded-2xl flex items-center justify-center gap-x-2 text-sm tracking-wider">
          <i class="fa-solid fa-sign-in-alt"></i>
          <span>SIGN IN</span>
        </button>
      </form>

      <div class="mt-6 text-center">
        <p class="text-xs text-slate-500">Demo credentials: <span class="font-mono text-violet-400">admin / demo123</span></p>
      </div>
    </div>

    <p class="text-center text-slate-500 text-xs mt-8">Powered by SMMGen • Hosted on Render.com</p>
  </div>
</body>
</html>
